VALUES (-1, 350.0, 'BD', TIMESTAMPTZ '2026-05-11T19:02:02.728894+00:00', 5.0, 'Baldo', TIMESTAMPTZ '2026-05-11T19:02:02.728893+00:00', 'Baldr', '3e526e9e-a9c3-4812-afc8-423a7e79542a', 0, 1);

INSERT INTO my."MyTableRef" ("Id", "Amount", "Created", "LastChanged", "LastChangedBy", "MyInfo", "ParentId", "RowVersion")
VALUES (-3, 200.0, TIMESTAMPTZ '2026-05-11T19:02:02.728908+00:00', TIMESTAMPTZ '2026-05-11T19:02:02.728908+00:00', 'Stefan', 'OtherData', -2, 0);

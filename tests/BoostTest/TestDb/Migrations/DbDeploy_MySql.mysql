    CONSTRAINT `PK_my_MyTableRef` PRIMARY KEY (`Id`),
    CONSTRAINT `FK_my_MyTableRef_my_MyTable_ParentId` FOREIGN KEY (`ParentId`) REFERENCES `my_MyTable` (`Id`) ON DELETE RESTRICT
) CHARACTER SET=utf8mb4;


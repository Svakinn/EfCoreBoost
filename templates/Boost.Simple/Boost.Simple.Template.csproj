<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <PackageType>Template</PackageType>
    <PackageId>EfCore.Boost.Template.Simple</PackageId>
    <Title>EfCore.Boost Simple Template</Title>
    <Authors>Junie</Authors>
      <Description>
          Minimal EfCore.Boost multi-project template with Model and Migrate projects, designed to provide a clean, production-oriented starting point. Includes a simple IpInfo entity, one view, and two routines to demonstrate core patterns without unnecessary complexity.
      </Description>
    <PackageTags>dotnet-new;templates;EFCore;Boost</PackageTags>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PackageReadmeFile>PackageREADME.md</PackageReadmeFile>
    <TargetFramework>net8.0</TargetFramework>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <!-- Prevent the SDK from trying to compile the template source files -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoWarn>$(NoWarn);NU5110;NU5111;NU5128</NoWarn>
    <Version>1.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <None Include="LICENSE.txt" Pack="true" PackagePath="" />
    <None Include="PackageREADME.md" Pack="true" PackagePath="" />
    <!-- Template source files for IDE visibility and packing -->
    <Content Include="**\*" Exclude="**\bin\**;**\obj\**;**\.vs\**;Boost.Simple.Template.csproj;artifacts\**;LICENSE.txt;PackageREADME.md" Pack="true" />
  </ItemGroup>

</Project>

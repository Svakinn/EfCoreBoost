ALTER DATABASE CHARACTER SET utf8mb4;

CREATE TABLE `BoostSchemaX_IpInfo` (
    `Id` bigint NOT NULL AUTO_INCREMENT,
    `IpNo` varchar(50) CHARACTER SET utf8mb4 NOT NULL,
    `HostName` varchar(512) CHARACTER SET utf8mb4 NULL,
    `Processed` bit(1) NOT NULL,
    `LastChangedUtc` datetime(6) NOT NULL,
    CONSTRAINT `PK_BoostSchemaX_IpInfo` PRIMARY KEY (`Id`)
) CHARACTER SET=utf8mb4 COMMENT='Received IP numbers with reverse lookup data';

INSERT INTO `BoostSchemaX_IpInfo` (`Id`, `HostName`, `IpNo`, `LastChangedUtc`, `Processed`)
VALUES (-1, 'Localhost', '127.0.0.1', TIMESTAMP '1970-01-01 00:00:00', TRUE);

CREATE UNIQUE INDEX `IpNoIdx` ON `BoostSchemaX_IpInfo` (`IpNo`);

CREATE INDEX `IX_BoostSchemaX_IpInfo_LastChangedUtc` ON `BoostSchemaXIpInfo` (`LastChangedUtc` DESC);

CREATE INDEX `IX_BoostSchemaX_IpInfo_Processed` ON `BoostSchemaX_IpInfo` (`Processed`);

